  "keyFeatures": [
    "Next.js 15 with TypeScript and React 19",
    "MetaMask and HashPack wallet integration via WalletConnect",
    "Mirror Node REST API integration for account data",
    "Token balance viewer with HTS metadata",
    "Transaction history browser",
    "Interactive tutorial system",
    "shadcn/ui component library with Tailwind CSS",
    "Storybook component development"
  ],
  "publicApiSurface": [
    "MirrorNodeService.getInstance()",
    "MirrorNodeService.getAccountInfo(accountId)",
    "MirrorNodeService.getAccountTokenBalances(accountId)",
    "MirrorNodeService.getTokenInfo(tokenId)",
    "MirrorNodeService.getAccountTransactions(accountId, limit)",
    "MirrorNodeService.getAccountTokenBalancesWithInfo(accountId)",
    "MirrorNodeService.formatHbar(tinybars)",
    "MirrorNodeService.formatTokenAmount(amount, decimals)",
    "HederaService.getInstance()",
    "HederaService.sendHbar(fromAccountId, toAccountId, amount)",
    "HederaService.createToken(accountId, name, symbol, initialSupply, decimals)",
    "useWallet() hook",
    "WalletContext provider",
    "<WalletConnect /> component",
    "<AccountDetails /> component",
    "<ApiPlayground /> component"
  ]
}
